+# Defer device connection until first tool call. Constructing Mobile() does
+# blocking I/O (uiautomator2 connect + device.info HTTP probe) that can hang
+# indefinitely if the device's atx-agent isn't ready. Doing it at module
+# import time would prevent mcp.run() from answering the JSON-RPC `initialize`
+# handshake, causing MCP clients to time out their launch probe even though
+# the server is alive. Connecting lazily lets the handshake succeed; if the
+# device truly isn't reachable, the failure surfaces as a tool error with a
+# real message instead of a silent hang.
+_mobile_lock = threading.Lock()
+_mobile_singleton: 'Mobile | None' = None
+
+def _mobile() -> Mobile:
+    global _mobile_singleton
+    if _mobile_singleton is None:
+        with _mobile_lock:
+            if _mobile_singleton is None:
+                _mobile_singleton = Mobile(
+                    device=None if not args.emulator else 'emulator-5554'
+                )
+    return _mobile_singleton
+
+def _device():
+    return _mobile().get_device()
 
